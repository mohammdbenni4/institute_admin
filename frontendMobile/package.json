{
	"name": "institute-administration-teacher-mobile",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:app": "BUILD_TARGET=app vite build --mode app",
		"icons": "node scripts/make-icons.mjs",
		"android:fit": "node scripts/android-fit.mjs",
		"android:assets": "capacitor-assets generate --android",
		"cap:sync": "npm run build:app && cap sync && npm run android:fit && npm run android:assets",
		"cap:android": "npm run build:app && cap sync android && npm run android:fit && npm run android:assets && cap open android",
		"apk:debug": "npm run build:app && cap sync android && npm run android:fit && npm run android:assets && cd android && ./gradlew assembleDebug",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@capacitor/android": "^7.6.7",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^7.6.7",
		"@eslint/js": "^9.15.0",
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.8.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/node": "^22.9.0",
		"@typescript-eslint/eslint-plugin": "^8.15.0",
		"@typescript-eslint/parser": "^8.15.0",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.15.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.0",
		"globals": "^15.12.0",
		"postcss": "^8.5.15",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.8",
		"svelte": "^5.2.0",
		"svelte-check": "^4.1.0",
		"svelte-eslint-parser": "^0.43.0",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.6.3",
		"vite": "^5.4.11"
	},
	"dependencies": {
		"@capacitor/app": "^7.1.2",
		"@capacitor/core": "^7.6.7",
		"@capacitor/local-notifications": "^7.0.6",
		"@capacitor/network": "^7.0.4",
		"@capacitor/preferences": "^7.0.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"clsx": "^2.1.1",
		"dexie": "^4.4.4",
		"sharp": "^0.35.2",
		"tailwind-merge": "^3.6.0"
	}
}
