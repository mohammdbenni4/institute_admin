# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Application
APP_NAME="Institute Administration API"
ENVIRONMENT=local            # local | test | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed origins (the SvelteKit dev server)
CORS_ORIGINS=["http://localhost:5173"]

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true => structured JSON logs (production)

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=institute_administration
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Authentication / JWT — CHANGE jwt_secret_key OUTSIDE LOCAL!
JWT_SECRET_KEY=insecure-development-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap super-admin (created by `make seed`)
SUPERADMIN_EMAIL=SuperAdmin@gmail.com
SUPERADMIN_PASSWORD=admin
SUPERADMIN_FULL_NAME=مدير النظام
